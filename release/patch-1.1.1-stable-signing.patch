diff --git a/README.md b/README.md
index d549431..1e328a9 100644
--- a/README.md
+++ b/README.md
@@ -20,3 +20,5 @@
 Откройте папку проекта в Android Studio и запустите приложение на телефоне или эмуляторе.
 
 APK автоматически собирается через GitHub Actions после изменений в `main`.
+
+Если Android пишет, что приложение конфликтует с другим пакетом, удалите старую установку один раз и поставьте APK версии 1.1.1 или новее. Дальнейшие обновления будут ставиться поверх, потому что проект использует постоянный ключ подписи.
diff --git a/app/build.gradle b/app/build.gradle
index 4ac5aa8..448083a 100644
--- a/app/build.gradle
+++ b/app/build.gradle
@@ -6,11 +6,29 @@ android {
     namespace "com.example.salesprofit"
     compileSdk 35
 
+    signingConfigs {
+        release {
+            storeFile file("sales-profit.keystore")
+            storePassword "salesprofit2026"
+            keyAlias "salesprofit"
+            keyPassword "salesprofit2026"
+        }
+    }
+
     defaultConfig {
         applicationId "com.example.salesprofit"
         minSdk 23
         targetSdk 35
-        versionCode 2
-        versionName "1.1"
+        versionCode 3
+        versionName "1.1.1"
+    }
+
+    buildTypes {
+        debug {
+            signingConfig signingConfigs.release
+        }
+        release {
+            signingConfig signingConfigs.release
+        }
     }
 }
